{
  "name": "robot-soldadura-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "PWA de consulta y asistencia para operación del robot Kawasaki BA006L con fuente EWM Titan XQ 350 Plus.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "build:standalone": "tsc -b && vite build --config vite.config.standalone.ts",
    "watch:standalone": "vite build --watch --config vite.config.standalone.ts",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.2.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
